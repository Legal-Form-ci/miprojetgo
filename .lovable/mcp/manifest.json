{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://vqrkajytqbrwvynxeezl.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "miprojet-go-mcp",
      "version": "0.1.0",
      "title": "MiProjet Go"
    },
    "tools": [
      {
        "name": "echo",
        "title": "Echo",
        "description": "Echo the input text back to the caller. Useful to verify MCP connectivity.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "description": "Text to echo back."
            }
          },
          "required": [
            "text"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_operations",
        "title": "List operations",
        "description": "List recent financial operations for the signed-in MiProjet Go user.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows to return (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_operation",
        "title": "Create operation",
        "description": "Record a new income or expense operation for the signed-in MiProjet Go user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "entree",
                "sortie"
              ],
              "description": "entree = income, sortie = expense"
            },
            "montant": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Amount in FCFA"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "categorie": {
              "type": "string",
              "minLength": 1
            },
            "mode_paiement": {
              "type": "string",
              "minLength": 1,
              "description": "cash, mobile_money, carte, virement, ..."
            },
            "note": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "montant",
            "description",
            "categorie",
            "mode_paiement"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
